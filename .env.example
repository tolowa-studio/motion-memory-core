# Motion Memory Core — copy to .env and fill in. NEVER commit .env.

# Bearer token every client must present to the gateway.
# Generate a strong one:  openssl rand -hex 32
STASH_TOKEN=change-me

# Postgres password (self-host).
POSTGRES_PASSWORD=change-me

# Embeddings + reasoning provider (any OpenAI-compatible API: OpenAI, OpenRouter, etc.)
STASH_OPENAI_API_KEY=sk-your-key
STASH_OPENAI_BASE_URL=https://api.openai.com/v1
